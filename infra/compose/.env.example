# Copy to .env and fill in.

# --- Service ---
PDLC_ENVIRONMENT=dev
PDLC_LOG_LEVEL=info

# --- Database ---
PDLC_DB_URL=postgresql+asyncpg://postgres:pdlc@postgres:5432/pdlc

# --- Redis ---
PDLC_REDIS_URL=redis://redis:6379/0

# --- Auth ---
PDLC_AUTH_MODE=local
PDLC_JWT_SECRET=change-me-in-production

# --- LLM defaults ---
# bedrock | anthropic | vertex | azure | openai | gemini | ollama
PDLC_DEFAULT_LLM_PROVIDER=bedrock
PDLC_BEDROCK_REGION=us-east-1

# For air-gapped:
# PDLC_DEFAULT_LLM_PROVIDER=ollama
# PDLC_OLLAMA_ENDPOINT=http://ollama:11434

# --- Clickstream ---
# jsonl (dev) | postgres (self-host) | firehose (SaaS)
PDLC_CLICKSTREAM_SINK=postgres

# --- AWS (only if using Bedrock / Firehose / S3) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
