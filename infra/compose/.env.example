# Copy to .env and fill in.

# --- Service ---
PDLC_ENVIRONMENT=dev
PDLC_LOG_LEVEL=info

# --- Database ---
PDLC_DB_URL=postgresql+asyncpg://postgres:pdlc@postgres:5432/pdlc

# --- Redis ---
PDLC_REDIS_URL=redis://redis:6379/0

# --- Durability (Phase H bundle 1) ---
# Durable, multi-process graph state (needs Postgres). Off => in-process MemorySaver.
PDLC_USE_POSTGRES_CHECKPOINTER=true
# Run graph turns on the Arq worker instead of inline in the API (needs Redis +
# the Redis bus for pending delivery). Off => synchronous inline dispatch.
PDLC_USE_ARQ_DISPATCH=false
# Cross-process WebSocket fan-out via Redis pub/sub (+ live night-shift verdict
# streaming). Off => in-process in-memory bus. Required if USE_ARQ_DISPATCH=true.
PDLC_USE_REDIS_BUS=true

# --- Persistence (Phase H bundle 3) ---
# Artifacts: memory | filesystem | s3.  filesystem = mounted volume (self-host).
PDLC_ARTIFACT_STORE=filesystem
PDLC_ARTIFACT_DIR=/var/lib/pdlcflow/artifacts
# For s3/MinIO: PDLC_ARTIFACT_STORE=s3 + the endpoint below + AWS_* creds.
# PDLC_S3_ENDPOINT_URL=http://minio:9000
# Durable tasks (Beads replacement) + analytics rollups in Postgres.
PDLC_TASK_STORE=postgres
PDLC_ANALYTICS_BACKEND=postgres

# --- Evals (Phase J) ---
# Off => the eval harness is a strict no-op. On => score agent output at major
# steps + emit eval.scored/eval.blocked events (see /v1/admin/evals/summary).
PDLC_RUN_EVALS=false
# LLM-as-judge tier (resolves via the provider factory; needs PDLC_WIRE_LLM=true,
# otherwise a deterministic stub judge is used).
PDLC_JUDGE_TIER=opus
# Opt-in blocking: comma-separated eval ids that BLOCK their gate on failure.
# Empty => measure-only. e.g. PDLC_EVAL_BLOCKING=groundedness,citation
PDLC_EVAL_BLOCKING=

# --- Auth ---
PDLC_AUTH_MODE=local
PDLC_JWT_SECRET=change-me-in-production

# --- LLM defaults ---
# bedrock | anthropic | vertex | azure | openai | gemini | ollama
PDLC_DEFAULT_LLM_PROVIDER=bedrock
PDLC_BEDROCK_REGION=us-east-1

# For air-gapped:
# PDLC_DEFAULT_LLM_PROVIDER=ollama
# PDLC_OLLAMA_ENDPOINT=http://ollama:11434

# --- Clickstream ---
# jsonl (dev) | postgres (self-host) | firehose (SaaS)
PDLC_CLICKSTREAM_SINK=postgres

# --- AWS (only if using Bedrock / Firehose / S3) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
