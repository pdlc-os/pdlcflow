# pdlcflow deployment config. Either run ./setup.sh (interactive — fills this in
# + generates secrets) or copy to .env and edit. Defaults give a working stack;
# the LLM stays an offline stub until you wire credentials.

# Image version to run (pin to a release, e.g. 1.5.0; or `latest`).
PDLCFLOW_VERSION=latest

# --- Database / cache (service names resolve inside the compose network) ---
# App connects as the non-superuser pdlc_app role (RLS enforced); migrations as owner.
PDLC_DB_URL=postgresql+asyncpg://pdlc_app:pdlc_app@postgres:5432/pdlc
PDLC_MIGRATION_DB_URL=postgresql+asyncpg://postgres:pdlc@postgres:5432/pdlc
POSTGRES_PASSWORD=pdlc
PDLC_REDIS_URL=redis://redis:6379/0

# --- Durable backends ---
PDLC_USE_POSTGRES_CHECKPOINTER=true
PDLC_USE_REDIS_BUS=true
PDLC_ARTIFACT_STORE=filesystem
PDLC_ARTIFACT_DIR=/var/lib/pdlcflow/artifacts
PDLC_TASK_STORE=postgres
PDLC_ANALYTICS_BACKEND=postgres
PDLC_CLICKSTREAM_SINK=postgres

# --- Auth (off => open API; on => Bearer JWT, org from token) ---
PDLC_AUTH_REQUIRED=false
PDLC_AUTH_MODE=local
PDLC_JWT_SECRET=change-me                       # setup.sh generates a strong one
# PDLC_BOOTSTRAP_ADMIN_EMAIL=admin@yourco.com
# PDLC_BOOTSTRAP_ADMIN_PASSWORD=change-me

# --- LLM (off => deterministic offline stub; on => real provider) ---
PDLC_WIRE_LLM=false
PDLC_DEFAULT_LLM_PROVIDER=bedrock               # bedrock|anthropic|openai|gemini|azure|vertex|ollama
PDLC_JUDGE_TIER=premium                         # premium|balanced|economy
# Provide the active provider's credentials (only the one you use):
# bedrock:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1            # boto3 credential chain
# PDLC_BEDROCK_REGION=us-east-1   # region the engine's Bedrock client actually uses
# anthropic:  ANTHROPIC_API_KEY=...
# openai:     OPENAI_API_KEY=...
# gemini:     GOOGLE_API_KEY=...
# azure:      AZURE_OPENAI_API_KEY=...   AZURE_OPENAI_ENDPOINT=https://<res>.openai.azure.com
# vertex:     GOOGLE_APPLICATION_CREDENTIALS=/path/sa.json   GOOGLE_CLOUD_PROJECT=...   GOOGLE_CLOUD_REGION=us-east5
# ollama:     PDLC_OLLAMA_ENDPOINT=http://localhost:11434

# --- Secrets (per-repo VCS tokens, etc.) ---
PDLC_SECRETS_BACKEND=encrypted                 # encrypted (default) | vault | env
PDLC_SECRET_KEY=                               # Fernet key (setup.sh generates) — required for 'encrypted'
# PDLC_SECRET_CACHE_TTL_S=300                   # BYOK: resolved tenant-key cache TTL (0 disables)
# PDLC_LLM_PROBE_TIMEOUT_S=10                   # provider connectivity probe budget (POST /admin/models/test)
# PDLC_LLM_HEALTH_INTERVAL_S=0                  # >0: probe the instance default for /health/ready (needs PDLC_WIRE_LLM)
# PDLC_ALLOW_PRIVATE_LLM_ENDPOINTS=false        # allow probing private/loopback endpoints (local Ollama)
# Vault (only if PDLC_SECRETS_BACKEND=vault). Bundle it: docker compose --profile vault up -d
# PDLC_VAULT_ADDR=http://vault:8200
# PDLC_VAULT_TOKEN=
# PDLC_VAULT_MOUNT=secret
# PDLC_VAULT_PATH_PREFIX=pdlcflow/repos

# --- Evals + live streaming ---
PDLC_RUN_EVALS=false
PDLC_EVAL_BLOCKING=
PDLC_STREAM_TOKENS=true

# --- Observability (OpenTelemetry → Grafana + Streamlit Nexus dashboard) ---
# Off by default. Turn on with `pdlcflow observability up` (sets this to true and
# starts the `observability` compose profile). See docs/wiki/19-observability.md.
PDLC_OTEL_ENABLED=false
# PDLC_OTEL_ENDPOINT=http://otel-collector:4317  # OTLP/gRPC collector endpoint
# PDLC_OTEL_SERVICE_NAME=pdlc-engine
# PDLC_OTEL_CONSOLE_EXPORT=false                 # also print spans to stdout (debug)

# --- MinIO (only used when PDLC_ARTIFACT_STORE=s3) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# To put artifacts in MinIO/S3, also set:
# PDLC_ARTIFACT_STORE=s3
# PDLC_S3_ENDPOINT_URL=http://minio:9000        # omit for real AWS S3
# PDLC_S3_ARTIFACTS_BUCKET=pdlcflow-artifacts
# PDLC_S3_EVENTS_BUCKET=pdlcflow-events

# --- Subscription CLI providers (single-user self-host, local process only) ---
# PDLC_ENABLE_CLI_PROVIDERS=true                 # then set PDLC_DEFAULT_LLM_PROVIDER=claude_code|codex|gemini_cli
# (Refused when PDLC_AUTH_REQUIRED=true. Not for this Docker deploy — run the engine locally with the CLI logged in.)

# --- Optional advanced settings (sensible defaults shown) ---
# PDLC_ENVIRONMENT=dev                           # dev|staging|prod
# PDLC_LOG_LEVEL=info                            # debug|info|warning|error
# PDLC_JWT_ALG=HS256
# PDLC_JWT_TTL_S=43200                           # 12h
# PDLC_PG_POOL_MAX_SIZE=20
# PDLC_USE_ARQ_DISPATCH=false                    # enqueue graph turns to the worker
# PDLC_CLICKSTREAM_SINK=postgres                 # postgres|jsonl|firehose
# PDLC_FIREHOSE_STREAM_NAME=pdlcflow-events      # when clickstream sink=firehose (AWS)
# PDLC_CORS_ORIGINS=["http://localhost:5173"]
