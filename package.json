{
  "name": "pdlcflow-monorepo",
  "private": true,
  "version": "1.10.0",
  "description": "PDLC reimagined as a LangGraph + AWS Bedrock SaaS",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "infra/cdk"
