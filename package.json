    "prettier": "^3.3.3",
    "typescript": "^5.6.0",
    "@types/node": "^22.5.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0"
